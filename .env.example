NODE_ENV=development
PORT=5000

MONGO_URI=mongodb://localhost:27017/asaan-taqreeb

JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_REFRESH_EXPIRES_IN=7d

# Email Service Configuration (supports Gmail, Outlook/Hotmail/Office365, or Brevo out of the box)
EMAIL_USER=your_email_or_smtp_username
EMAIL_PASS=your_smtp_key_or_password
# Optional: The email address the recipient sees (defaults to EMAIL_USER if not set)
# EMAIL_FROM=helpline@yourdomain.com
# Optional: The custom display name the recipient sees (e.g. "Asaan Taqreeb Helpline")
# EMAIL_FROM_NAME="Asaan Taqreeb Helpline"

# To use Brevo, uncomment and set the service name:
# EMAIL_SERVICE=brevo

# Optional: Use only if you want to use a custom SMTP server instead of default ones
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_SECURE=false

# Firebase Cloud Messaging (FCM) Configuration for Realtime Push Notifications
# You can either:
# 1. Place 'firebase-service-account.json' directly in the backend root directory.
# 2. Or set this variable as a base64 encoded JSON string of the service account file.
FIREBASE_SERVICE_ACCOUNT=your_base64_encoded_service_account_json_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here


